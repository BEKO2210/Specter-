  "users": [
    {
      "name": "deploy-bot",
      "console_access": true,
      "mfa_enabled": false,
      "attached_policies": ["AdministratorAccess"],
      "access_keys": [{ "age_days": 430, "last_used_days": 380 }]
    },
    {
      "name": "backup-service",
      "console_access": false,
      "mfa_enabled": true,
      "access_keys": [{ "age_days": 20, "last_used_days": 2 }]
    }
  ],
  "roles": [
    { "name": "ci-deploy", "trust": "*", "attached_policies": ["AdministratorAccess"] }
